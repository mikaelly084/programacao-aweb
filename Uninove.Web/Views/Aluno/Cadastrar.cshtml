@model Uninove.Web.Models.Aluno

@{
    ViewData["Title"] = "Cadastro de Aluno";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Formulário de Cadastro de Aluno</h3>
        </div>
        <div class="card-body">
            <form asp-action="Cadastrar" method="post">
                
                <div class="form-group mb-3">
                    <label asp-for="Nome" class="form-label font-weight-bold">Nome Completo</label>
                    <input asp-for="Nome" class="form-control" placeholder="Digite o nome do aluno" />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label font-weight-bold">E-mail</label>
                    <input asp-for="Email" class="form-control" placeholder="exemplo@uninove.edu.br" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="RA" class="form-label font-weight-bold">Registro Acadêmico (RA)</label>
                    <input asp-for="RA" class="form-control" placeholder="Digite apenas números" />
                    <span asp-validation-for="RA" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Curso" class="form-label font-weight-bold">Curso</label>
                    <select asp-for="Curso" class="form-control">
                        <option value="">-- Selecione o Curso --</option>
                        <option value="Análise e Desenvolvimento de Sistemas">Análise e Desenvolvimento de Sistemas</option>
                        <option value="Ciência da Computação">Ciência da Computação</option>
                        <option value="Sistemas de Informação">Sistemas de Informação</option>
                        <option value="Engenharia de Software">Engenharia de Software</option>
                    </select>
                    <span asp-validation-for="Curso" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="DataNascimento" class="form-label font-weight-bold">Data de Nascimento</label>
                    <input asp-for="DataNascimento" class="form-control" type="date" />
                    <span asp-validation-for="DataNascimento" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-success btn-lg px-5">Cadastrar Aluno</button>
            </form>
        </div>
    </div>
</div>